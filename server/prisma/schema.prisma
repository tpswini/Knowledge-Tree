generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

model User {
  id             Int             @id @default(autoincrement())
  name           String
  email          String          @unique
  password       String
  level          Int             @default(1)
  xp             Int             @default(0)
  learningStreak Int             @default(0)
  studyHours     Float           @default(0)
  lastActiveDate DateTime?
  cards          KnowledgeCard[]
  journals       JournalEntry[]
  goals          Goal[]
  createdAt      DateTime        @default(now())
  updatedAt      DateTime        @updatedAt
}

model KnowledgeCard {
  id          Int      @id @default(autoincrement())
  title       String
  explanation String?  @db.Text
  source      String?
  category    String?
  tags        String?
  difficulty  String?
  timeSpent   Int?
  mood        String?
  attachments String?
  isFavorite  Boolean  @default(false)
  isArchived  Boolean  @default(false)
  content     Json?
  userId      Int
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model JournalEntry {
  id               Int      @id @default(autoincrement())
  date             DateTime @default(now())
  whatILearned     String   @db.Text
  biggestChallenge String   @db.Text
  questions        String   @db.Text
  tomorrowsGoal    String   @db.Text
  mood             String
  userId           Int
  user             User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt
}

model Goal {
  id        Int      @id @default(autoincrement())
  title     String
  type      String   // 'Daily', 'Weekly', 'Monthly'
  deadline  DateTime?
  status    String   // 'Pending', 'In Progress', 'Completed'
  progress  Int      @default(0)
  userId    Int
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}
